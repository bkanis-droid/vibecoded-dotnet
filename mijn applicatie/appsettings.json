{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MedicalDb": "Data Source=medical.db"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY:-your-default-secret-key-change-in-production}",
    "Issuer": "MedicalApp",
    "Audience": "MedicalAppUsers",
    "ExpirationMinutes": 60
  }
}
